# Polymarket Latency Arbitrage Bot Configuration

# Price feed thresholds (basis points, default 50 = $0.50)
THRESHOLD_BPS=50

# Minimum time between trades in milliseconds
MIN_HOLD_MS=1500

# Starting paper wallet balance
STARTING_BALANCE=6.96

# Percentage of portfolio to invest per trade (0.10 = 10%)
PORTFOLIO_PCT=0.10

# Enable paper trading (set to false for live trading when implemented)
PAPER_TRADING=true

# --- Spread-Based Edge Detection (NEW) ---

# Minimum Binance-Chainlink spread required to enter (in USD)
# This is your edge indicator - only trade when spread is large enough
# Example: If Binance=$72,450 and Chainlink=$72,430, spread=$20
# Recommended: 20.0 (only enter when spread > $20)
MIN_EDGE_SPREAD=20.0

# Exit when spread closes by this percentage (0.3 = exit when 70% closed)
# Example: Entry spread=$30, exit when current spread < $9 (70% closed)
# Lower = faster exits, Higher = hold longer for Chainlink to catch up
# Recommended: 0.3 (exit at 70% closure)
SPREAD_CLOSE_PCT=0.3

# --- Execution Speed ---

# Spike sustain time in ms (how long spike must persist before entry)
# Set to 0 for instant entry, 10-20ms to filter single-tick noise
# Lower = faster entry but more false signals. Recommended: 0-10ms
SPIKE_SUSTAIN_MS=0

# Execution delay in ms (simulates network + CLOB latency in paper mode)
# Measure this from live trading and set accordingly
# Paper mode: Use realistic delay (50-150ms typical)
# Live mode: This is ignored (real network latency applies)
EXECUTION_DELAY_MS=100

# Simulated slippage in basis points for paper trading
# Default: 50 bps = 0.5% slippage
SLIPPAGE_BPS=50

# --- Risk Management ---

# Maximum orders per minute (rate limiting)
MAX_ORDERS_PER_MINUTE=20

# Maximum daily loss in USD (resets at midnight UTC)
MAX_DAILY_LOSS=10.0

# Maximum exposure per market in USD
MAX_EXPOSURE_PER_MARKET=50.0

# Maximum drawdown percentage from peak balance
MAX_DRAWDOWN_PCT=30.0
