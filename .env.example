# Polymarket Latency Arbitrage Bot Configuration

# Price feed thresholds (basis points, default 50 = $0.50)
THRESHOLD_BPS=50

# Minimum time between trades in milliseconds
MIN_HOLD_MS=1500

# Starting paper wallet balance
STARTING_BALANCE=6.96

# Percentage of portfolio to invest per trade (0.10 = 10%)
PORTFOLIO_PCT=0.10

# Enable paper trading (set to false for live trading when implemented)
PAPER_TRADING=true

# --- Execution Speed ---

# Spike sustain time in ms (how long spike must persist before entry)
# Lower = faster entry but more false signals. Default: 50ms
SPIKE_SUSTAIN_MS=50

# Execution delay in ms (simulates network + CLOB latency in paper mode)
# Measure this from live trading and set accordingly. Default: 300ms
EXECUTION_DELAY_MS=300

# Simulated slippage in basis points for paper trading
# Default: 50 bps = 0.5% slippage
SLIPPAGE_BPS=50

# --- Exit Strategy ---

# Spike faded: exit if BTC reverses X% from peak since entry
# Example: 0.02 = exit if BTC drops 0.02% from highest price since entry
SPIKE_FADED_PCT=0.02

# Spike faded persistence in milliseconds
# How long the reversal must persist before exiting
SPIKE_FADED_MS=200

# Minimum hold time in milliseconds
# No exits (except extreme reversal) for this duration after entry
# Give Polymarket time to update their chart
MIN_HOLD_MS=1500

# --- Risk Management ---

# Maximum entry price (shares above this price won't be traded)
# Default: 0.80 = 80 cents
MAX_ENTRY_PRICE=0.80

# Minimum entry price (shares below this price won't be traded)
# Default: 0.05 = 5 cents
MIN_ENTRY_PRICE=0.05

# Maximum orders per minute (rate limiting)
MAX_ORDERS_PER_MINUTE=20

# Maximum daily loss in USD (resets at midnight UTC)
MAX_DAILY_LOSS=10.0

# Maximum exposure per market in USD
MAX_EXPOSURE_PER_MARKET=50.0

# Maximum drawdown percentage from peak balance
MAX_DRAWDOWN_PCT=30.0
