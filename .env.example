# Polymarket Latency Arbitrage Bot Configuration

# ============================================
# AUTHENTICATION (required for live trading)
# ============================================

# Your private key for live trading (leave empty for paper trading)
POLYMARKET_PRIVATE_KEY=

# Wallet type: "gnosis" for browser wallet, "eoa" for standalone EOA
WALLET_TYPE=gnosis

# Polygon RPC for on-chain approvals (live trading only)
POLYGON_RPC_URL=https://rpc.ankr.com/polygon

# ============================================
# TRADING MODE
# ============================================

# Paper trading mode (true = simulate, false = live)
PAPER_TRADING=true

# Starting balance in USDC (for paper trading)
STARTING_BALANCE=6.96

# ============================================
# ENTRY SETTINGS
# ============================================

# Spike threshold in USD (2000 = $20 minimum spike to enter)
THRESHOLD_BPS=2000

# Percentage of balance to use per trade (0.20 = 20%)
PORTFOLIO_PCT=0.20

# Max share price to enter (0.80 = don't buy shares above 80 cents)
MAX_ENTRY_PRICE=0.80

# Min share price to enter (0.05 = don't buy shares below 5 cents)
MIN_ENTRY_PRICE=0.05

# ============================================
# EXIT SETTINGS
# ============================================

# Trend reversal: exit if BTC reverses by X% of the spike magnitude from entry
# Example: 50 = if $30 spike, exit when BTC reverses $15 from entry price
TREND_REVERSAL_PCT=50

# Spike faded: exit if BTC reverses by X% of the spike magnitude from peak/trough
# Example: 50 = if $30 spike, exit when BTC reverses $15 from best price reached
SPIKE_FADED_PCT=50

# Spike faded persistence in milliseconds
# How long the reversal must persist before exiting
SPIKE_FADED_MS=200

# Minimum hold time in milliseconds
# No exits (except trend_reversal) for this duration after entry
MIN_HOLD_MS=1500

# Stop-loss percentage from entry price
# Exit if share price drops by this percentage from entry
# 30 = exit if price drops 30% from entry (e.g., 10 cent entry -> exit at 7 cents)
# 0 = disabled
STOP_LOSS_PCT=30

# ============================================
# HOLD TO RESOLUTION
# ============================================

# Minimum share price to enter hold mode (0.80 = 80 cents)
# In hold mode, we hold positions near market end if share price is high
HOLD_MIN_SHARE_PRICE=0.80

# Safety margin in USD from price_to_beat to exit in hold mode
# Exit if BTC gets within this distance of price_to_beat (e.g., 20 = exit if within $20)
# This uses our 1.5-2s edge to exit before Chainlink updates and share price crashes
HOLD_SAFETY_MARGIN=15
# ============================================
# RISK MANAGEMENT
# ============================================

# Maximum orders per minute (rate limiting)
MAX_ORDERS_PER_MINUTE=20

# Maximum daily loss in USD (resets at midnight UTC)
MAX_DAILY_LOSS=10.0

# Maximum exposure per market in USD
MAX_EXPOSURE_PER_MARKET=50.0

# Maximum drawdown percentage from peak balance
MAX_DRAWDOWN_PCT=0.30

# ============================================
# FEES & EXECUTION
# ============================================

# Taker fee rate for Crypto markets (0.072 per Polymarket docs)
CRYPTO_FEE_RATE=0.072

# Simulated execution delay in milliseconds (paper trading only)
EXECUTION_DELAY_MS=300

# Simulated slippage in basis points (paper trading only)
SLIPPAGE_BPS=50

# ============================================
# ADVANCED
# ============================================

# EMA alpha for Binance/Chainlink offset baseline
EMA_ALPHA=0.03

# Spike sustain time in ms (how long spike must persist before entry)
SPIKE_SUSTAIN_MS=50

# Skip entry if share price is within this distance of 0.50 (worst fee zone)
MIN_PRICE_DISTANCE=0.05