# Polymarket Latency Arbitrage Bot Configuration

# --- Core ---

# Your private key for live trading (leave empty for paper trading)
POLYMARKET_PRIVATE_KEY=

# Paper trading mode (true = simulate, false = live)
PAPER_TRADING=true

# Starting balance in USDC
STARTING_BALANCE=27.0

# --- Entry ---

# Spike threshold in USD (20 = $20 minimum adjusted spike to enter)
THRESHOLD_BPS=2000

# Percentage of balance to use per trade (0.10 = 10%)
PORTFOLIO_PCT=0.1

# Max share price to enter (0.70 = don't buy shares above 70 cents)
MAX_ENTRY_PRICE=0.7

# --- Exit ---

# Trailing stop percentage from peak (10.0 = exit if price drops 10% from highest)
TRAILING_STOP_PCT=10

# Spike faded threshold (0.25 = exit if spike drops to 25% of entry spike)
SPIKE_FADED_PCT=0.25

# --- Fees ---

# Taker fee rate for Crypto markets (0.072 per Polymarket docs, 0 for maker/limit sells)
CRYPTO_FEE_RATE=0.072

# --- Baseline Correction ---

# EMA alpha for Binance/Chainlink offset baseline (lower = slower adaptation)
EMA_ALPHA=0.03

# --- Advanced ---

# Spike scaling factor for profit target (+0.01% per $1 spike above threshold)
SPIKE_SCALING_FACTOR=0.0001

# Simulated execution delay in milliseconds (300 = 300ms order latency simulation)
EXECUTION_DELAY_MS=300

# Simulated execution delay in milliseconds (300 = 300ms order latency simulation)
EXECUTION_DELAY_MS=300

# --- Hold to Resolution ---
# Required $ margin per second remaining (1.5 = need $90 margin with 60s left)
HOLD_MARGIN_PER_SECOND=1.5
# Only activate hold mode when <= this many seconds remain in the window
HOLD_MAX_SECONDS=90
# Max times BTC can cross price-to-beat in history before we refuse to hold
HOLD_MAX_CROSSINGS=2
PROFIT_TARGET_PCT=0
MAX_SPREAD_BPS=100
